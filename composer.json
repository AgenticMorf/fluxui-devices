{
    "name": "agenticmorf/fluxui-devices",
    "homepage": "https://github.com/AgenticMorf/fluxui-devices",
    "support": {
        "source": "https://github.com/AgenticMorf/fluxui-devices"
    },
    "description": "FluxUI front-end for managing devices and sessions using diego-ninja/laravel-devices",
    "keywords": ["laravel", "livewire", "fluxui", "devices", "sessions", "security"],
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Thompson",
            "email": "christhompsontldr@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "livewire/livewire": "^3.0|^4.0",
        "livewire/volt": "^1.0",
        "diego-ninja/laravel-devices": "^2.0"
    },
    "require-dev": {
        "christhompsontldr/laravel-docit": "^1.0",
        "laravel/framework": "^12.0",
        "livewire/flux": "^2.0",
        "orchestra/pest-plugin-testbench": "^4.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "AgenticMorf\\FluxuiDevices\\": "src/",
            "AgenticMorf\\FluxuiDevices\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "docit": "php vendor/bin/build-docs",
        "test": "vendor/bin/pest",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage",
        "test:type-coverage": "vendor/bin/pest --type-coverage",
        "test:mutation": "XDEBUG_MODE=coverage vendor/bin/pest --mutate --everything --covered-only --class=AgenticMorf\\\\FluxuiDevices"
    },
    "extra": {
        "laravel": {
            "providers": [
                "AgenticMorf\\FluxuiDevices\\FluxuiDevicesServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
